{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["helpers:pinGitHubActionDigests"],
  "platformCommit": "enabled",
  "labels": ["dependencies"],
  "prHourlyLimit": 0,
  "lockFileMaintenance": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^scripts/build\\.py$/"],
      "matchStrings": [
        "ENVOY_FILES_VERSION\\s*=\\s*\"(?<currentValue>v[^\"]+)\""
      ],
      "depNameTemplate": "curioswitch/envoy-files",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "matchDepNames": ["curioswitch/envoy-files"],
      "groupName": "envoy-files"
    },
    {
      "matchCategories": ["python"],
      "groupName": "Python dependencies"
    },
    {
      "matchManagers": ["rust"],
      "groupName": "Rust dependencies",
      "rangeStrategy": "bump"
    },
    {
      // We need to use an older version for compatibility
      "matchCurrentVersion": "11",
      "matchPackageNames": ["debian"],
      "enabled": false
    }
  ]
}
